{% props label, href="/", variant="primary" %}
{% if variant == "primary" %}
  {% set cls = "btn btn-primary" %}
{% elif variant == "secondary" %}
  {% set cls = "btn btn-secondary" %}
{% elif variant == "outline" %}
  {% set cls = "btn btn-outline" %}
{% else %}
  {% set cls = "btn btn-default" %}
{% endif %}

<a href="{{ href }}" class="{{ cls }}">{{ label }}</a>
