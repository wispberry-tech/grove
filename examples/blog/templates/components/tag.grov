{% props label, color="gray" %}
{% if color == "green" %}
  {% set cls = "tag tag-green" %}
{% elif color == "red" %}
  {% set cls = "tag tag-red" %}
{% elif color == "purple" %}
  {% set cls = "tag tag-purple" %}
{% elif color == "orange" %}
  {% set cls = "tag tag-orange" %}
{% elif color == "blue" %}
  {% set cls = "tag tag-brown" %}
{% else %}
  {% set cls = "tag tag-gray" %}
{% endif %}
<span class="{{ cls }}">{{ label }}</span>
