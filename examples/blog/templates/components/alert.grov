{% props type="info" %}
{% let %}
  icon = "ℹ"
  cls = "alert alert-info"

  if type == "warning"
    icon = "⚠"
    cls = "alert alert-warning"
  elif type == "error"
    icon = "✕"
    cls = "alert alert-error"
  elif type == "success"
    icon = "✓"
    cls = "alert alert-success"
  end
{% endlet %}
<div class="{{ cls }}">
  <span class="alert-icon">{{ icon }}</span>
  <div>{% slot %}{% endslot %}</div>
</div>
