{% props name, slug, image_url, price_display %}
<div class="card">
  <img src="{{ image_url }}" alt="{{ name }}">
  <div class="card-body">
    <h3>
      <a href="/product/{{ slug }}">{{ name }}</a>
    </h3>
    <div>{{ price_display | safe }}</div>
    {% slot "badge" %}{% endslot %}
  </div>
</div>
